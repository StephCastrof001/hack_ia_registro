# Plantilla de variables de entorno — COPIAR a .env y rellenar.
# .env.example SE commitea (sin valores). .env NUNCA se commitea.

# --- Supabase (pestaña API Keys) — DB + Storage foto + Auth admin ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Resend (email de aprobacion) ---
RESEND_API_KEY=
EMAIL_FROM=HACK IA <no-reply@send.klipso.xxx>

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
ADMIN_EMAILS=admin@example.com
